{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Wearable IoT App",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["app.py"],
      "group": {
        "kind": "run",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
