{
    "configurations": [
        {
            "name": "PlatformIO",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/.pio/libdeps/nodemcuv2/**",
                "${env:USERPROFILE}/.platformio/packages/framework-arduinoespressif8266/cores/esp8266",
                "${env:USERPROFILE}/.platformio/packages/framework-arduinoespressif8266/libraries/**",
                "${env:USERPROFILE}/.platformio/packages/framework-arduinoespressif8266/tools/sdk/include",
                "${env:USERPROFILE}/.platformio/packages/toolchain-xtensa/include",
                "${env:USERPROFILE}/.platformio/packages/toolchain-xtensa/xtensa-lx106-elf/include"
            ],
            "defines": [
                "PLATFORMIO=60106",
                "ESP8266",
                "ARDUINO_ARCH_ESP8266",
                "ARDUINO_ESP8266_NODEMCU",
                "F_CPU=80000000L",
                "LWIP_OPEN_SRC",
                "ARDUINO=10805"
            ],
            "compilerPath": "${env:USERPROFILE}/.platformio/packages/toolchain-xtensa/bin/xtensa-lx106-elf-gcc.exe",
            "cStandard": "c11",
            "cppStandard": "c++11",
            "intelliSenseMode": "gcc-x64"
        }
    ],
    "version": 4
}
